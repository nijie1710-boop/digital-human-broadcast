DATABASE_URL="file:./dev.db"
DIGITAL_HUMAN_PROVIDER="aliyun"

# 离线 mock 可用于不消耗费用的本地流程测试：
# DIGITAL_HUMAN_PROVIDER="mock"
ALIYUN_DASHSCOPE_API_KEY=""
ALIYUN_MODEL_REGION="beijing"
PUBLIC_BASE_URL=""
# ALIYUN_TTS_MODEL="qwen3-tts-flash"
# ALIYUN_TTS_VOICE="Cherry"
# ALIYUN_VIDEO_MODEL="wan2.2-s2v"
# 声音克隆：上传样本后创建阿里音色 ID；后续 TTS 必须使用同一个 target model。
# 默认使用 CosyVoice 音色复刻，返回 voice_id 后后续 TTS 使用 cosyvoice-v3.5-flash。
# ALIYUN_VOICE_CLONE_MODEL="voice-enrollment"
# ALIYUN_VOICE_CLONE_TARGET_MODEL="cosyvoice-v3.5-flash"
# ALIYUN_VOICE_CLONE_PREPROCESS="false"
# ALIYUN_VOICE_CLONE_MAX_SECONDS="20"
# 费用预估单价，可按阿里云账单或模型定价调整。默认按 wan2.2-s2v 480P 0.5 元/秒、720P 0.9 元/秒、Qwen-TTS 0.8 元/万字符估算。
# ALIYUN_VIDEO_RESOLUTION="480P"
# ALIYUN_VIDEO_PRICE_CNY_PER_SECOND="0.5"
# ALIYUN_DETECT_PRICE_CNY_PER_IMAGE="0.004"
# ALIYUN_TTS_PRICE_CNY_PER_10K_CHARS="0.8"

# 真实 talking-head 生成：设置为 did 后会调用 D-ID Talks API。
# D_ID_API_KEY="your-d-id-basic-api-key"
# D_ID_VOICE_PROVIDER="microsoft"
# D_ID_VOICE_ID="zh-CN-XiaoxiaoNeural"
