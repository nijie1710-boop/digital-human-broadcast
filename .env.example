DATABASE_URL="file:./dev.db"
PORT=5173
DIGITAL_HUMAN_PROVIDER="heygen"
# 可切换：
# DIGITAL_HUMAN_PROVIDER="mock"
# DIGITAL_HUMAN_PROVIDER="aliyun"

# 离线 mock 可用于不消耗费用的本地流程测试：
# DIGITAL_HUMAN_PROVIDER="mock"
ALIYUN_DASHSCOPE_API_KEY=""
DASHSCOPE_API_KEY=""
ALIYUN_MODEL_REGION="beijing"
PUBLIC_BASE_URL=""
# ALIYUN_TTS_MODEL="qwen3-tts-flash"
# ALIYUN_TTS_VOICE="Cherry"
# 视频模式：
# - s2v：单张图片 + 音频，成本较高且动作较僵硬
# - videoretalk：基础视频 + 音频，口型替换更自然，需给数字人上传基础视频
ALIYUN_VIDEO_MODE="videoretalk"
ALIYUN_VIDEO_MODEL="wan2.2-s2v"
ALIYUN_VIDEO_RESOLUTION="480P"
# ALIYUN_VIDEORETALK_MODEL="videoretalk"
# 声音克隆：上传样本后创建阿里音色 ID；后续 TTS 必须使用同一个 target model。
# 默认使用 CosyVoice 音色复刻，返回 voice_id 后后续 TTS 使用 cosyvoice-v3.5-flash。
# ALIYUN_VOICE_CLONE_MODEL="voice-enrollment"
# ALIYUN_VOICE_CLONE_TARGET_MODEL="cosyvoice-v3.5-flash"
# ALIYUN_VOICE_CLONE_PREPROCESS="false"
# ALIYUN_VOICE_CLONE_MAX_SECONDS="20"
# 费用预估单价，可按阿里云账单或模型定价调整。默认按 videoretalk 0.08 元/秒、wan2.2-s2v 480P 0.5 元/秒估算。
# ALIYUN_VIDEO_PRICE_CNY_PER_SECOND="0.5"
# ALIYUN_VIDEORETALK_PRICE_CNY_PER_SECOND="0.08"
# ALIYUN_DETECT_PRICE_CNY_PER_IMAGE="0.004"
# ALIYUN_TTS_PRICE_CNY_PER_10K_CHARS="0.8"

# 真实 talking-head 生成：设置为 did 后会调用 D-ID Talks API。
# D_ID_API_KEY="your-d-id-basic-api-key"
# D_ID_VOICE_PROVIDER="microsoft"
# D_ID_VOICE_ID="zh-CN-XiaoxiaoNeural"

# HeyGen 官方 API：真实 key 只放本地 .env，不要提交到 GitHub。
HEYGEN_API_KEY=""
HEYGEN_API_BASE="https://api.heygen.com"
HEYGEN_DEFAULT_AVATAR_ID=""
HEYGEN_DEFAULT_VOICE_ID=""
HEYGEN_DEFAULT_RESOLUTION="1080p"
HEYGEN_DEFAULT_ASPECT_RATIO="9:16"
# 生成前费用预估，不影响实际扣费；实际以 HeyGen 后台为准。
HEYGEN_PRICE_USD_PER_SECOND="0.05"
USD_TO_CNY_RATE="7.2"
# HeyGen 生成细节：本地图片数字人会走 image-to-video；非默认背景会作为 background 传入。
HEYGEN_AVATAR_FIT="contain"
HEYGEN_EXPRESSIVENESS="medium"
HEYGEN_REMOVE_BACKGROUND="true"
# 默认不启用 HeyGen 字幕参数。需要字幕建议后续用 FFmpeg 后处理烧录，避免 API 字幕样式和页面样式不一致。
HEYGEN_ENABLE_CAPTIONS="false"
HEYGEN_ENABLE_MOTION_PROMPT="false"
HEYGEN_MOTION_PROMPT=""
HEYGEN_BACKGROUND_IMAGE_URL=""
HEYGEN_VOICE_SPEED="1"
HEYGEN_VOICE_PITCH="0"
HEYGEN_VOICE_VOLUME="1"
# HeyGen Voice Clone：建议上传 30-120 秒干净人声；默认开启降噪。
HEYGEN_REMOVE_BACKGROUND_NOISE="true"
