generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String          @id @default(uuid())
  email     String          @unique
  name      String
  role      String          @default("admin")
  createdAt DateTime        @default(now())
  avatars   Avatar[]
  voices    Voice[]
  templates Template[]
  jobs      GenerationJob[]
  projects  Project[]
  jobLogs   JobLog[]
}

model Avatar {
  id               String          @id @default(uuid())
  userId           String          @default("default-user")
  name             String
  gender           String
  style            String
  previewImage     String
  sourceImage      String
  sourceVideo      String?
  provider         String          @default("mock")
  providerAvatarId String?
  status           String          @default("active")
  isDefault        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id])
  jobs             GenerationJob[]
  projects         Project[]

  @@index([userId])
}

model Voice {
  id              String          @id @default(uuid())
  userId          String          @default("default-user")
  name            String
  gender          String
  language        String
  style           String
  sampleUrl       String
  duration        String
  provider        String          @default("mock")
  providerVoiceId String?
  providerModel   String?
  providerStatus  String?
  providerPayload String?
  providerError   String?
  status          String          @default("ready")
  isDefault       Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id])
  jobs            GenerationJob[]
  projects        Project[]

  @@index([userId])
}

model Template {
  id               String   @id @default(uuid())
  userId           String   @default("default-user")
  name             String
  category         String
  coverUrl         String
  scriptPrompt     String
  subtitleStyle    String
  backgroundConfig String
  introOutroConfig String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model GenerationJob {
  id               String    @id @default(uuid())
  userId           String    @default("default-user")
  title            String
  script           String
  avatarId         String
  voiceId          String
  subtitleStyle    String
  backgroundConfig String
  introOutroConfig String
  provider         String    @default("mock")
  providerTaskId   String?
  providerStatus   String?
  providerPayload  String?
  audioUrl         String?
  videoUrl         String?
  status           String    @default("pending")
  progress         Int       @default(0)
  stage            String    @default("创建任务")
  errorMessage     String?
  resultVideoUrl   String?
  coverUrl         String?
  duration         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  startedAt        DateTime?
  finishedAt       DateTime?
  user             User      @relation(fields: [userId], references: [id])
  avatar           Avatar    @relation(fields: [avatarId], references: [id])
  voice            Voice     @relation(fields: [voiceId], references: [id])
  project          Project?
  logs             JobLog[]

  @@index([userId])
}

model Project {
  id        String         @id @default(uuid())
  userId    String         @default("default-user")
  title     String
  script    String
  avatarId  String
  voiceId   String
  jobId     String?        @unique
  videoUrl  String
  coverUrl  String
  duration  String
  status    String         @default("ready")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id])
  avatar    Avatar         @relation(fields: [avatarId], references: [id])
  voice     Voice          @relation(fields: [voiceId], references: [id])
  job       GenerationJob? @relation(fields: [jobId], references: [id])

  @@index([userId])
}

model JobLog {
  id        String        @id @default(uuid())
  jobId     String
  userId    String        @default("default-user")
  step      String
  status    String
  progress  Int
  message   String?
  createdAt DateTime      @default(now())
  job       GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])

  @@index([jobId])
  @@index([userId])
}
